# =============================================================
# StockPulse VN — Environment Variables Template
# Copy to backend/.env and fill in real values
# NEVER commit .env to git
# =============================================================

# --- Application ---
APP_ENV=development                        # development | staging | production
APP_SECRET_KEY=change-me-min-32-chars-long-random-string
FRONTEND_URL=http://localhost:3000         # Next.js URL (prod: https://app.stockpulse.vn)

# --- Database (PostgreSQL via Supabase) ---
# Local dev: postgresql://stockpulse:stockpulse_dev@localhost:5433/stockpulse
# Supabase:  postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://stockpulse:stockpulse_dev@localhost:5433/stockpulse

# --- Supabase ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs:
#   - http://localhost:3000/auth/callback  (dev)
#   - https://app.stockpulse.vn/auth/callback  (prod)
GOOGLE_CLIENT_ID=<google-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<google-client-secret>

# --- Telegram Bot ---
# Get token from @BotFather: /newbot
TELEGRAM_BOT_TOKEN=<bot-token>
TELEGRAM_WEBHOOK_SECRET=<random-secret-for-webhook-validation>

# --- Redis (Upstash) ---
# Local dev: redis://localhost:6380
# Upstash:   rediss://:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6380

# --- PostHog Analytics ---
# Self-hosted or cloud: https://app.posthog.com
POSTHOG_API_KEY=phc_<your-key>
POSTHOG_HOST=https://app.posthog.com
